{
  "expo": {
    "name": "GlassNotes",
    "slug": "glass-notes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "scheme": "glassnotes",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/logo.jpeg"
      },
      "package": "com.federent.glassnotes",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.jpeg",
          "color": "#8B5CF6"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GlassNotes to access your photos so you can insert images into notes.",
          "cameraPermission": "Allow GlassNotes to access your camera to take photos for your notes."
        }
      ],
      [
        "expo-file-system"
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2ad84cd-60ee-4e1d-8fb1-9245448b945d"
      }
    }
  }
}
